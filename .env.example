# Torok environment variables (all optional)

# Default: fully useful with no keys.
# Retrieval uses the local Sefaria-derived library + curated fallbacks.

# Optional grounded language model (server-side only; never exposed to the browser).
# Free-tier provider quotas and terms may change — do not assume permanent free inference.
# TOROK_LLM_API_KEY=
# Or: OPENAI_API_KEY=
# TOROK_LLM_BASE_URL=https://api.openai.com/v1
# TOROK_LLM_MODEL=gpt-4o-mini
# TOROK_LLM_TIMEOUT_MS=8000

# Legacy flags (unused when TOROK_LLM_* is set)
# TOROK_PROVIDER=enabled
# TOROK_API_KEY=
